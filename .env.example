# Telegram Bot Token (Obtained from @BotFather)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# WebApp URL (URL of your frontend HTML portal, e.g. https://yourdomain.com/index.html)
WEB_APP_URL=https://your-tma-portal-hostname/index.html

# Network Proxy Configuration
# IMPORTANT: For developers in Mainland China, you MUST specify your local proxy server address 
# (e.g. http://127.0.0.1:7890 or http://127.0.0.1:10809) here, otherwise the bot will fail to establish 
# connection with Telegram server. Keep it empty or commented out if you are running on a VPS outside China.
TELEGRAM_PROXY=http://127.0.0.1:7890
